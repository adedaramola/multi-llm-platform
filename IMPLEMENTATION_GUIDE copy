```bash
aws dynamodb update-item \
  --table-name ai-platform-api-keys-production \
  --key '{"key_hash": {"S": "<hash>"}}' \
  --update-expression "SET active = :false" \
  --expression-attribute-values '{":false": {"BOOL": false}}'
